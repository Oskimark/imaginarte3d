# ==============================================================================
# ARCHIVO DE CONFIGURACIÓN DE ENTORNO (IMAGINARTE3D)
# Copia este archivo a `.env` y completa con tus datos reales de Supabase y Mercado Pago.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. BASE DE DATOS (Supabase PostgreSQL con Prisma)
# ------------------------------------------------------------------------------
# DATABASE_URL: URL para la conexión general (usa el puerto 6543 para Transaction Pooling/PgBouncer)
# Asegúrate de colocar tu contraseña real en lugar de [PASSWORD] y tu referencia de proyecto en [PROJECT-REF].
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL: URL directa a la base de datos (puerto 5432) usada para migraciones de Prisma.
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ------------------------------------------------------------------------------
# 2. BUCKET DE IMÁGENES Y CLIENTE SUPABASE
# ------------------------------------------------------------------------------
# Obtén estos datos en: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu-anon-key-de-supabase"
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key-de-supabase-para-servidor"

# ------------------------------------------------------------------------------
# 3. SEGURIDAD Y SESIÓN DEL ADMINISTRADOR
# ------------------------------------------------------------------------------
# Contraseña fija para entrar a /admin
ADMIN_PASSWORD="cambiame_por_una_contrasena_segura"

# Clave secreta para encriptar cookies o tokens de sesión (puedes generar una con `openssl rand -base64 32`)
NEXTAUTH_SECRET="cambiame_por_un_secreto_largo_y_seguro"

# ------------------------------------------------------------------------------
# 4. MERCADO PAGO (Pasarela de Pago)
# ------------------------------------------------------------------------------
# Obtén estos datos en: Mercado Pago Dashboard -> Tus Integraciones
MERCADOPAGO_ACCESS_TOKEN="TEST-your-mercadopago-access-token"
NEXT_PUBLIC_MP_PUBLIC_KEY="TEST-your-mercadopago-public-key"
